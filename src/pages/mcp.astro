---
import Layout from "@/layout/Layout.astro";
import { Content as ContentZh } from "@/data/mcp.md";
import { Content as ContentEn } from "@/data/mcp-en.md";

const lang = Astro.props.lang ?? "zh";
const isEn = lang === "en";

const pageTitle = isEn ? "MCP Server" : "MCP伺服器";
const description = isEn ? "Connect to the MCP Server, arrange your personal agenda, manage your itinerary, and share with others." : "連線至 MCP Server，安排您的專屬議程、管理行程並與他人分享。";
---

<Layout title={pageTitle} lang={lang}>
	<main class={isEn ? "en" : ""}>
		<div class="mcp-header">
			<h1>{pageTitle}</h1>
			<p>{description}</p>
		</div>
		<div class="layout-container">
			<aside class="platform-switch">
				<a href="#chatgpt" class="switch-btn active">ChatGPT</a>
				<!-- <a href="#claude" class="switch-btn">Claude</a> -->
				<a href="#vscode" class="switch-btn">VSCode</a>
			</aside>
			<div class="content-area">
				<article class="markdown-body">
					{isEn ? <ContentEn /> : <ContentZh />}
				</article>
			</div>
		</div>
	</main>
</Layout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		// Handle switch-btn active status
		const switchBtns = document.querySelectorAll(".switch-btn");
		const headings = document.querySelectorAll(".markdown-body h2");

		if (headings.length > 0) {
			const observerOptions = {
				root: null,
				rootMargin: "-20% 0px -60% 0px",
				threshold: 0
			};

			const observer = new IntersectionObserver(entries => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const id = entry.target.id;
						switchBtns.forEach(btn => {
							if (btn.getAttribute("href") === `#${id}`) {
								btn.classList.add("active");
							} else {
								btn.classList.remove("active");
							}
						});
					}
				});
			}, observerOptions);

			headings.forEach(h2 => observer.observe(h2));
		}

		switchBtns.forEach(btn => {
			btn.addEventListener("click", () => {
				switchBtns.forEach(b => b.classList.remove("active"));
				btn.classList.add("active");
			});
		});

		const copyUrls = document.querySelectorAll(".copy-mcp-url") as NodeListOf<HTMLElement>;
		copyUrls.forEach(el => {
			const aTag = el.querySelector("a");
			if (aTag) {
				aTag.removeAttribute("href");
				aTag.style.pointerEvents = "none";
				aTag.style.color = "inherit";
			}

			el.addEventListener("click", async e => {
				e.preventDefault();
				const url = "https://mcp.sitcon.org/mcp";
				try {
					await navigator.clipboard.writeText(url);
					const isEn = el.dataset.lang === "en";
					const originalText = el.innerText;
					el.innerText = isEn ? "Copied!" : "已複製！";
					setTimeout(() => {
						el.innerText = originalText;
					}, 2000);
				} catch (err) {
					console.error("Failed to copy:", err);
				}
			});
		});
	});
</script>

<style>
	main {
		min-height: 100vh;
		padding: 8rem 2rem 4rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		background-color: #a97c21;
	}

	.mcp-header {
		text-align: center;
		margin-bottom: 4rem;
		width: 100%;
		max-width: 1200px;
		color: #fff;
	}

	.mcp-header h1 {
		font-size: 3rem;
		font-family: "GenKiMinTW", serif;
		margin-bottom: 1rem;
	}

	.mcp-header p {
		font-size: 1rem;
		opacity: 0.9;
	}

	.layout-container {
		display: flex;
		width: 100%;
		max-width: 1200px;
		gap: 2rem;
		justify-content: center;
	}

	.platform-switch {
		width: 20%;
		display: flex;
		flex-direction: column;
		background-color: #ffffff;
		padding: 1.5rem;
		border-radius: 1rem;
		overflow: hidden;
		height: fit-content;
	}

	.switch-btn {
		padding: 0.7rem;
		border: none;
		border-bottom: 1px solid #000;
		color: #333;
		text-decoration: none;
		font-size: 1rem;
		font-weight: bold;
		text-align: start;
		transition: all 0.3s ease;
	}

	.switch-btn:last-child {
		border-bottom: none;
	}

	.switch-btn:hover {
		background: #f0f0f0;
	}

	.switch-btn.active {
		background: #e0e0e0; /* Grey for active */
		color: #000;
	}

	.content-area {
		width: 66.666%;
		background-color: #ffffff;
		padding: 2rem;
		border-radius: 1rem;
	}

	.markdown-body {
		width: 100%;
		color: #333;
	}

	.markdown-body :global(h1) {
		font-size: 2.5rem;
		margin-bottom: 2rem;
		border-bottom: 2px solid rgba(0, 0, 0, 0.1);
		padding-bottom: 0.5rem;
		line-height: 1.6;
	}

	.markdown-body :global(h2) {
		font-size: 1.8rem;
		color: #000000;
		line-height: 1.6;
	}

	.markdown-body :global(h3) {
		margin-bottom: 1rem;
		margin-top: 2rem;
	}

	.markdown-body :global(p) {
		margin-bottom: 0;
	}

	.markdown-body :global(ul),
	.markdown-body :global(ol) {
		margin-bottom: 1.2rem;
		padding-left: 1.5rem;
	}

	.markdown-body :global(li) {
		margin-bottom: 0.5rem;
	}

	.markdown-body :global(blockquote) {
		border-left: 4px solid #a97c21;
		padding: 0.5rem 1rem;
		background: rgba(169, 124, 33, 0.1);
		margin: 2rem 0;
		font-style: italic;
	}

	.markdown-body :global(hr) {
		border: 0;
		border-top: 1px solid rgba(0, 0, 0, 0.1);
		margin: 3rem 0;
	}

	.markdown-body :global(img) {
		max-width: 100%;
		width: 600px;
		height: auto;
		border-radius: 0.5rem;
		display: block;
		margin: 1rem 0;
	}

	.markdown-body :global(img[src*="C3"]) {
		width: 300px;
	}

	@media (max-width: 768px) {
		.layout-container {
			flex-direction: column;
		}

		.platform-switch {
			width: 100%;
			flex-direction: row;
		}

		.switch-btn {
			flex: 1;
		}

		.content-area {
			width: 100%;
		}
	}

	@media (max-width: 600px) {
		main {
			padding: 6rem 1.5rem 3rem;
		}

		.mcp-header h1 {
			font-size: 2.5rem;
		}

		.markdown-body :global(h1) {
			font-size: 2rem;
		}

		.markdown-body :global(h2) {
			font-size: 1.5rem;
		}
	}
</style>
